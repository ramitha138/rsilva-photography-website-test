{
  "name": "rsilva-photography-website-test",
  "version": "1.0.0",
  "description": "Black-box Playwright automation framework for the R.Silva Photography website.",
  "private": false,
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test",
    "ai:triage": "node scripts/ai-triage.js",
    "test:e2e:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "install:browsers": "playwright install --with-deps"
  },
  "keywords": [
    "playwright",
    "test-automation",
    "e2e",
    "accessibility",
    "ci"
  ],
  "author": "Ramit",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.54.1"
  }
}
